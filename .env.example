# ─────────────────────────────────────────────────────────────────────────────
# MathAI — Root .env.example (local development)
# Copy to .env and fill in real values.
# See docs/ENV_CHECKLIST.md for the full variable reference.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database (required) ─────────────────────────────────────────────────────
# Postgres connection string. Used by Prisma everywhere.
DATABASE_URL="postgresql://user:password@localhost:5432/mathai_dev"

# ─── Auth (required) ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Must be identical in Vercel and Render.
NEXTAUTH_SECRET="replace-me-with-openssl-rand-hex-32"

# Only needed locally (Vercel auto-detects, Render doesn't run Next.js).
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional — omit to disable Google sign-in)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ─── App URLs ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001/api"

# ─── Express API ─────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV="development"

# CORS — not needed locally (localhost:3000 is allowed by default).
# In production (Render), set this to your Vercel URL.
# CORS_ORIGIN="https://mathai.vercel.app"

# ─── AI Provider ─────────────────────────────────────────────────────────────
# "mock"           = no API key needed (default for local dev)
# "vercel_gateway" = production — routes all AI calls through Vercel AI Gateway
# "anthropic"      = legacy direct Anthropic API (not recommended)
AI_PROVIDER="mock"

# ─── Vercel AI Gateway (required when AI_PROVIDER=vercel_gateway) ─────────────
#
# Package : @ai-sdk/gateway (createGateway)
# Base URL: https://ai-gateway.vercel.sh/v1/ai  (default — only override if proxying)
# Auth    : Authorization: Bearer <API key>
#
# How to get your key:
#   vercel.com/dashboard → AI → your gateway → Authentication → Create API Key
#   Then set up BYOK in gateway Settings → Providers → Add Anthropic key
#
# VERCEL_AI_GATEWAY_URL and VERCEL_AI_GATEWAY_KEY are retired — use these instead:
#
# AI_GATEWAY_API_KEY="vgk_..."
# AI_GATEWAY_BASE_URL="https://ai-gateway.vercel.sh/v1/ai"   # optional override

# ─── Model selection (optional — these are the defaults) ─────────────────────
# Model IDs use the format: <provider>/<model-name>
# Full catalog: vercel.com/ai-gateway/models
#
# AI_MODEL_DEFAULT="anthropic/claude-haiku-4.5"      # fast/cheap — questions, hints
# AI_MODEL_EXPLANATION="anthropic/claude-sonnet-4.5" # rich — explanations, recommendations

# ─── Legacy direct Anthropic (only if AI_PROVIDER=anthropic) ─────────────────
# ANTHROPIC_API_KEY="sk-ant-..."

# Mock provider delay (ms) — simulate latency in dev
# MOCK_AI_DELAY_MS=0

# ─── Frontend mock mode (optional) ──────────────────────────────────────────
# Set to "true" to run frontend without the Express API at all.
# NEXT_PUBLIC_USE_MOCK_DATA="true"
