# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/mathai_dev"

# ─── Auth ──────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── AI / Vercel AI Gateway ────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY="sk-..."
AI_GATEWAY_URL="https://gateway.ai.cloudflare.com/v1/..."
AI_MODEL_DEFAULT="claude-3-5-sonnet-20241022"

# ─── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_VISUAL_EXPLANATIONS=true
ENABLE_ADAPTIVE_ENGINE=true
ENABLE_GAMIFICATION=true

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001/api"
NODE_ENV="development"
