# ─────────────────────────────────────────────────────────────────────────────
# MathAI — Root .env.example (local development)
# Copy to .env and fill in real values.
# See docs/ENV_CHECKLIST.md for the full variable reference.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database (required) ─────────────────────────────────────────────────────
# Postgres connection string. Used by Prisma everywhere.
DATABASE_URL="postgresql://user:password@localhost:5432/mathai_dev"

# ─── Auth (required) ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Must be identical in Vercel and Render.
NEXTAUTH_SECRET="replace-me-with-openssl-rand-hex-32"

# Only needed locally (Vercel auto-detects, Render doesn't run Next.js).
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional — omit to disable Google sign-in)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ─── App URLs ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001/api"

# ─── Express API ─────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV="development"

# CORS — not needed locally (localhost:3000 is allowed by default).
# In production (Render), set this to your Vercel URL.
# CORS_ORIGIN="https://mathai.vercel.app"

# ─── AI Provider ─────────────────────────────────────────────────────────────
# "mock" = no API key needed (default)
# "anthropic" = requires ANTHROPIC_API_KEY
AI_PROVIDER="mock"
# ANTHROPIC_API_KEY="sk-ant-..."
# AI_MODEL_DEFAULT="claude-3-5-haiku-20241022"
# AI_MODEL_EXPLANATION="claude-3-5-sonnet-20241022"

# Mock provider delay (ms) — simulate latency in dev
# MOCK_AI_DELAY_MS=0

# ─── Frontend mock mode (optional) ──────────────────────────────────────────
# Set to "true" to run frontend without the Express API at all.
# NEXT_PUBLIC_USE_MOCK_DATA="true"
