# ─────────────────────────────────────────────────────────────────────────────
# MathAI — Render Environment Variables
# Set these in the Render dashboard (Settings → Environment).
# NODE_ENV=production is already set in render.yaml — do NOT duplicate it here.
# PORT is injected by Render automatically — do NOT set it manually.
# See docs/ENV_CHECKLIST.md for the full variable reference.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Required ────────────────────────────────────────────────────────────────

# Postgres connection string (e.g. from Supabase, Neon, or Render Postgres)
DATABASE_URL="postgresql://user:password@host:5432/mathai?schema=public"

# Must match the NEXTAUTH_SECRET set in Vercel — tokens won't decrypt otherwise.
NEXTAUTH_SECRET="same-value-as-vercel"

# Your Vercel frontend URL — used for CORS.
CORS_ORIGIN="https://mathai.vercel.app"

# ─── AI (optional — defaults to mock) ───────────────────────────────────────

# Switch to "anthropic" when ready to use real AI.
# AI_PROVIDER="anthropic"
# ANTHROPIC_API_KEY="sk-ant-..."
# AI_MODEL_DEFAULT="claude-3-5-haiku-20241022"
# AI_MODEL_EXPLANATION="claude-3-5-sonnet-20241022"
