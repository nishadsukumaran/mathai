{
  "name": "mathai",
  "version": "0.1.0",
  "private": true,
  "description": "MathAI \u2014 Gamified AI-powered math learning platform for children",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "prisma generate --schema=database/schema/schema.prisma",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:e2e": "playwright test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "db:generate": "prisma generate --schema=database/schema/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=database/schema/schema.prisma",
    "db:seed": "ts-node database/seed/seed.ts",
    "db:studio": "prisma studio --schema=database/schema/schema.prisma"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0",
    "@playwright/test": "^1.41.0",
    "turbo": "^1.12.0",
    "prisma": "^5.8.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "postcss-selector-parser": "^6.0.0",
    "postcss-nested": "^6.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "zod": "^3.22.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "prisma": {
    "schema": "database/schema/schema.prisma",
    "seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' database/seed/seed.ts"
  }
}
