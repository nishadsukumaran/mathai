{
  "name": "mathai",
  "version": "0.1.0",
  "private": true,
  "description": "MathAI — Gamified AI-powered math learning platform for children",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npx prisma generate --schema=database/schema/schema.prisma || echo 'prisma generate skipped (will run in render:build)'",
    "dev": "turbo run dev",
    "dev:api": "npx tsx --watch api/server.ts",
    "build": "turbo run build",
    "build:api": "npx tsc --project tsconfig.json --noEmit || echo 'Type errors found (non-blocking for runtime)'",
    "start:api": "node --import tsx/esm api/server.ts",
    "render:build": "npm install --include=dev && npx prisma generate --schema=database/schema/schema.prisma && DIRECT_URL=${DIRECT_URL:-$DATABASE_URL} npx prisma migrate deploy --schema=database/schema/schema.prisma",
    "render:start": "npx tsx api/server.ts",
    "test": "turbo run test",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:e2e": "playwright test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "db:generate": "prisma generate --schema=database/schema/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=database/schema/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=database/schema/schema.prisma",
    "db:seed": "npx tsx database/seed.ts",
    "db:studio": "prisma studio --schema=database/schema/schema.prisma"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.0",
    "autoprefixer": "^10.4.0",
    "jest": "^29.7.0",
    "postcss": "^8.4.0",
    "postcss-nested": "^6.0.0",
    "postcss-selector-parser": "^6.0.0",
    "prisma": "^5.8.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "turbo": "^1.12.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/gateway": "^3.0.66",
    "@panva/hkdf": "^1.1.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@prisma/client": "^5.8.0",
    "ai": "^6.0.116",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^7.1.0",
    "jose": "^5.2.0",
    "morgan": "^1.10.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.7.0",
    "zod": "^3.22.0"
  },
  "engines": {
    "node": "20.x",
    "npm": ">=10.0.0"
  },
  "prisma": {
    "schema": "database/schema/schema.prisma",
    "seed": "npx tsx database/seed.ts"
  }
}
