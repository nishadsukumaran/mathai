\pard\pagebb\keepn\outlinelevel0\sb480\sa240\cf1\fs36\b 4. Authentication & Authorisation\b0\cf3\fs21\par
\pard\keepn\outlinelevel1\sb360\sa200\cf2\fs28\b 4.1 Authentication Flow\b0\cf3\fs21\par
\pard\qj\sb80\sa80\cf3\fs21 MathAI uses NextAuth.js v4 with the JWT session strategy. On successful sign-in the JWT callback embeds gradeLevel, role, and isActive from the database into a JWE-encrypted token. The Express API decrypts this same token on every protected request using the jose library with HKDF key derivation from NEXTAUTH_SECRET.\par
\pard\sb0\sa120\par
\pard\keepn\outlinelevel2\sb240\sa140\cf9\fs23\b Sign-in Methods\b0\cf3\fs21\par
\pard\sb60\sa60\li360\fi-180\cf3\fs21 \bullet  Email + password \u8212? CredentialsProvider; passwords stored as bcrypt-12 hashes\par
\pard\sb60\sa60\li360\fi-180\cf3\fs21 \bullet  Google OAuth \u8212? GoogleProvider (requires GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET). Callback URI: \{NEXTAUTH_URL\}/api/auth/callback/google\par
\pard\sb0\sa120\par
\pard\keepn\outlinelevel2\sb240\sa140\cf9\fs23\b JWT Token Payload\b0\cf3\fs21\par
\pard\sb0\sa0\li360\ri360\cf8\f1\fs17 \{\par
\pard\sb0\sa0\li360\ri360\cf8\f1\fs17   "sub":      "<user-uuid>",\par
\pard\sb0\sa0\li360\ri360\cf8\f1\fs17   "email":    "user@example.com",\par
\pard\sb0\sa0\li360\ri360\cf8\f1\fs17   "grade":    "G4",\par
\pard\sb0\sa0\li360\ri360\cf8\f1\fs17   "role":     "student",\par
\pard\sb0\sa0\li360\ri360\cf8\f1\fs17   "isActive": true,\par
\pard\sb0\sa0\li360\ri360\cf8\f1\fs17   "iat":      1710000000,\par
\pard\sb0\sa0\li360\ri360\cf8\f1\fs17   "exp":      1710086400\par
\pard\sb0\sa0\li360\ri360\cf8\f1\fs17 \}\par
\pard\sb0\sa120\par
\pard\keepn\outlinelevel1\sb360\sa200\cf2\fs28\b 4.2 Express API Auth Middleware\b0\cf3\fs21\par
\pard\qj\sb80\sa80\cf3\fs21 Every non-public route passes through authMiddleware (api/src/middleware/auth.ts). It extracts the Bearer token, decrypts the JWE using HKDF(SHA-256, NEXTAUTH_SECRET), validates claims, rejects disabled accounts, and attaches the decoded payload to req.user.\par
\pard\sb0\sa120\par
\pard\keepn\outlinelevel2\sb240\sa140\cf9\fs23\b Internal Service Routes\b0\cf3\fs21\par
\pard\qj\sb80\sa80\cf3\fs21 Routes under /api/internal/* skip the user JWT check and instead require the X-Service-Secret header to match INTERNAL_SERVICE_SECRET \u8212? a 32-byte cryptographic random value shared between Vercel and Render. Used to trigger AI topic generation post-signup.\par
\pard\sb0\sa120\par
\pard\keepn\outlinelevel1\sb360\sa200\cf2\fs28\b 4.3 Role-Based Access Control\b0\cf3\fs21\par
