# ─────────────────────────────────────────────────────────────────────────────
# MathAI — Next.js Frontend .env.example
# For local dev: copy to .env.local
# For Vercel: set these in the Vercel dashboard under Environment Variables.
# See docs/ENV_CHECKLIST.md for the full variable reference.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database (required at build time for prisma generate) ───────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/mathai_dev"

# ─── Auth (required) ─────────────────────────────────────────────────────────
NEXTAUTH_SECRET="replace-me-with-openssl-rand-hex-32"

# Only needed locally — Vercel auto-detects from VERCEL_URL.
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ─── App URLs (required) ────────────────────────────────────────────────────
# Local:  http://localhost:3000 / http://localhost:3001/api
# Vercel: https://mathai.vercel.app / https://mathai-api.onrender.com/api
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001/api"

# ─── Mock mode (optional) ───────────────────────────────────────────────────
# Bypass backend entirely — all hooks return mock data.
# NEXT_PUBLIC_USE_MOCK_DATA="true"
