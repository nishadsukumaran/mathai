# ─────────────────────────────────────────────────────────────────────────────
# MathAI — Next.js Frontend environment variables
# Local dev: copy to .env.local and fill in values
# Vercel:    set all non-commented vars in Project Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ────────────────────────────────────────────────────────────────
# Supabase pooler URL (port 5432 for local/direct, 6543 for pgBouncer in prod)
DATABASE_URL="postgresql://user:password@host:5432/mathai_dev"

# ─── Auth ────────────────────────────────────────────────────────────────────
# MUST be your production domain on Vercel — NextAuth uses this to build
# the Google OAuth callback URL: {NEXTAUTH_URL}/api/auth/callback/google
# Local:  http://localhost:3002
# Vercel: https://mathai.aiops.ae
NEXTAUTH_URL="http://localhost:3000"

# Generate with: openssl rand -hex 32
# Must be the same value on Vercel AND Render
NEXTAUTH_SECRET="replace-me-with-openssl-rand-hex-32"

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI to register: {NEXTAUTH_URL}/api/auth/callback/google
# Authorized JS origin to register:    {NEXTAUTH_URL}
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── App URLs ────────────────────────────────────────────────────────────────
# Local:  http://localhost:3002 / http://localhost:3001/api
# Vercel: https://mathai.aiops.ae / https://mathai-api.onrender.com/api
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001/api"

# ─── Internal service secret ─────────────────────────────────────────────────
# Shared secret between Next.js (Vercel) and Express API (Render).
# Used by the signup route to call /api/internal/generate-topics without a
# user JWT. Must match INTERNAL_SERVICE_SECRET on Render exactly.
# Generate with: openssl rand -hex 32
INTERNAL_SERVICE_SECRET="replace-me-with-openssl-rand-hex-32"

# ─── AI Provider ─────────────────────────────────────────────────────────────
# "mock" = no API key needed (dev/test only)
# "anthropic" = production, requires ANTHROPIC_API_KEY
AI_PROVIDER="mock"
ANTHROPIC_API_KEY=""
# AI_MODEL_DEFAULT="claude-3-5-haiku-20241022"
